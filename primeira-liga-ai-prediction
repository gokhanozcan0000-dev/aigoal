<script async defer src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8363649317786686" crossorigin="anonymous"></script>
<style>
:root{
  --bg:#0a0c14;--bg2:#0f1220;--card:#13172a;--border:#1e2340;
  --accent:#00e5ff;--accent2:#ff3d5a;--accent3:#ffe600;--accent4:#7c4dff;
  --text:#e8eaf6;--muted:#5a6280;
  --sidebar-w:220px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;overflow-x:hidden;}
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:linear-gradient(rgba(0,229,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,.025) 1px,transparent 1px);
  background-size:56px 56px;
}


/* ─── SIDEBAR ─── */
.sidebar{position:fixed;top:0;left:0;width:var(--sidebar-w);height:100vh;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:300;overflow-y:auto;transition:transform .25s;}
.sidebar .sb-section:last-child{margin-top:auto;}
.sidebar::-webkit-scrollbar{width:3px;}
.sidebar::-webkit-scrollbar-thumb{background:var(--border);}
.sb-logo{padding:10px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:flex-start;text-decoration:none;cursor:pointer;flex-shrink:0;}
.sb-section{padding:10px 0 4px;flex-shrink:0;}
.sb-section-label{font-size:9px;font-weight:700;letter-spacing:1.8px;text-transform:uppercase;color:var(--muted);padding:0 16px 6px;}
.sb-item{display:flex;align-items:center;gap:10px;padding:8px 16px;font-size:12px;font-weight:600;color:var(--muted);text-decoration:none;cursor:pointer;transition:background .15s,color .15s;border-left:2px solid transparent;white-space:nowrap;overflow:hidden;}
.sb-item:hover{background:rgba(0,229,255,.06);color:var(--text);}
.sb-item.active{background:rgba(0,229,255,.1);color:var(--accent);border-left-color:var(--accent);}
.sb-item .sb-flag{width:14px;height:10px;object-fit:cover;border-radius:2px;flex-shrink:0;box-shadow:0 1px 4px rgba(0,0,0,.55),0 0 0 .5px rgba(255,255,255,.08);opacity:.85;filter:saturate(.85);transition:opacity .15s,filter .15s;}
.sb-item:hover .sb-flag,.sb-item.active .sb-flag{opacity:1;filter:saturate(1.1);}
.sb-group-toggle .sb-flag{width:14px;height:10px;object-fit:cover;border-radius:2px;flex-shrink:0;box-shadow:0 1px 4px rgba(0,0,0,.55),0 0 0 .5px rgba(255,255,255,.08);opacity:.7;filter:saturate(.8);}
.sb-group-toggle:hover .sb-flag{opacity:.95;filter:saturate(1);}
.sb-item .sb-icon{width:18px;height:18px;flex-shrink:0;opacity:.7;}
.sb-item.active .sb-icon{opacity:1;}
.sb-divider{height:1px;background:var(--border);margin:8px 16px;}
.sb-badge{margin-left:auto;font-size:9px;font-weight:700;padding:2px 6px;border-radius:10px;background:rgba(0,229,255,.15);color:var(--accent);flex-shrink:0;}
.sb-badge.new{background:rgba(255,61,90,.15);color:var(--accent2);}
.sb-group-toggle{display:flex;align-items:center;gap:10px;padding:8px 16px;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;transition:color .15s;user-select:none;}
.sb-group-toggle:hover{color:var(--text);}
.sb-group-toggle .arrow{margin-left:auto;font-size:10px;transition:transform .2s;flex-shrink:0;}
.sb-group-toggle.open .arrow{transform:rotate(90deg);}
.sb-group-content{display:none;padding-left:8px;}
.sb-group-content.open{display:block;}

/* ─── MAIN ─── */
.main{margin-left:var(--sidebar-w);flex:1;display:flex;flex-direction:column;position:relative;z-index:1;min-width:0;}

/* ─── TOP NAV ─── */
.topnav{position:sticky;top:0;z-index:200;height:52px;background:rgba(10,12,20,.97);backdrop-filter:blur(18px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 24px;gap:12px;}
.topnav-left{display:flex;align-items:center;gap:12px;}
.topnav-breadcrumb{font-size:12px;color:var(--muted);}
.topnav-breadcrumb span{color:var(--text);font-weight:600;}
.live-badge{background:var(--accent2);color:#fff;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:1px;animation:blink 2s infinite;white-space:nowrap;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.5;}}
.topnav-right{display:flex;align-items:center;gap:10px;}
.week-chip{display:flex;align-items:center;gap:6px;background:rgba(0,229,255,.07);border:1px solid rgba(0,229,255,.2);border-radius:4px;padding:5px 11px;font-size:11px;font-weight:600;color:var(--accent);letter-spacing:.3px;white-space:nowrap;}
.week-chip::before{content:'';width:5px;height:5px;background:var(--accent);border-radius:50%;animation:blink 1.6s infinite;flex-shrink:0;}

/* ─── LANG SWITCHER ─── */
.lang-switcher{display:flex;gap:4px;align-items:center;}
.lang-btn{background:transparent;border:1px solid var(--border);color:var(--muted);font-size:10px;font-weight:700;padding:3px 8px;border-radius:3px;cursor:pointer;letter-spacing:.5px;transition:all .15s;font-family:'DM Sans',sans-serif;}
.lang-btn:hover{border-color:var(--accent);color:var(--accent);}
.lang-btn.active{background:rgba(0,229,255,.12);border-color:var(--accent);color:var(--accent);}

/* ─── CONTENT ─── */
.content{padding:0 0 60px;}

/* ─── PAGE VIEWS ─── */
.page{display:none;}
.page.active{display:block;}

/* ─── TITLE BAR ─── */
.title-bar{background:linear-gradient(135deg,#0c1030 0%,#141930 100%);border-bottom:1px solid var(--border);padding:16px 24px 14px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;}
.title-bar h1{font-family:'DM Sans',sans-serif;font-size:clamp(14px,2.2vw,22px);font-weight:700;letter-spacing:.5px;color:#fff;line-height:1.1;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.title-bar h1 .cy{color:var(--accent);}
.title-bar h1 .cr{color:var(--accent2);}
.league-country-tag{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:1px;background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:3px;padding:2px 6px;white-space:nowrap;flex-shrink:0;}
.title-sub{font-size:11px;color:var(--muted);margin-top:4px;}
.league-logo-header{height:34px;background:#fff;border-radius:6px;padding:3px 7px;object-fit:contain;display:inline-block;vertical-align:middle;}

/* ─── LEGEND ─── */
.legend-bar{padding:8px 24px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;gap:6px;flex-wrap:wrap;align-items:center;}
.leg{display:inline-flex;align-items:center;padding:3px 9px;border-radius:3px;font-size:11px;font-weight:700;letter-spacing:.3px;border:1px solid transparent;}
.l1{background:rgba(0,200,83,.1);color:#00c853;border-color:rgba(0,200,83,.25);}
.l1x{background:rgba(0,200,83,.06);color:#69f0ae;border-color:rgba(0,200,83,.18);}
.lx2{background:rgba(255,61,90,.07);color:#ff8a80;border-color:rgba(255,61,90,.18);}
.lkg{background:rgba(0,229,255,.08);color:#00e5ff;border-color:rgba(0,229,255,.25);}
.lu{background:rgba(199,125,255,.1);color:#c77dff;border-color:rgba(199,125,255,.25);}
.la{background:rgba(255,145,0,.08);color:#ffab40;border-color:rgba(255,145,0,.2);}
.leg-lbl{font-size:11px;color:var(--muted);font-weight:500;}

/* ─── TABLE ─── */
.table-wrap{overflow-x:auto;padding-bottom:6px;}
.table-wrap::-webkit-scrollbar{height:4px;}
.table-wrap::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
table{width:100%;border-collapse:collapse;min-width:660px;}
thead th{padding:10px 7px;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);text-align:center;background:var(--bg2);border-bottom:2px solid var(--border);white-space:nowrap;vertical-align:bottom;}
thead th:first-child{text-align:left;padding-left:20px;min-width:230px;}
.th-ai{padding-bottom:9px;}
.ai-hd{display:flex;flex-direction:column;align-items:center;gap:4px;}
.ai-hd svg{width:20px;height:20px;flex-shrink:0;}
.ai-hd .hn{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text);}
th.th-cl{background:rgba(0,229,255,.05);border-bottom:2px solid var(--accent);}
th.th-cl .hn{color:var(--accent);}
tbody tr{border-bottom:1px solid rgba(30,35,64,.7);transition:background .1s;}
tbody tr:hover{background:rgba(255,255,255,.022);}
tbody tr.dr{background:rgba(255,61,90,.03);}
tbody tr.dr:hover{background:rgba(255,61,90,.06);}
td.mc{padding:12px 20px;text-align:left;}
.mn{font-size:13px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px;flex-wrap:wrap;}
.mn .vs{color:var(--muted);font-weight:400;font-size:11px;margin:0 2px;}
.mn .tname{max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.dtag{display:inline-block;background:var(--accent2);color:#fff;font-size:8px;font-weight:700;letter-spacing:1.5px;padding:2px 6px;border-radius:2px;vertical-align:middle;}
.team-logo{width:22px;height:22px;object-fit:contain;flex-shrink:0;border-radius:2px;}
.match-meta{font-size:10px;color:var(--muted);margin-top:3px;display:flex;align-items:center;gap:4px;}
.match-time{font-family:'Bebas Neue',cursive;font-size:13px;color:var(--accent3);}
td.pc{padding:8px 5px;text-align:center;vertical-align:middle;}
td.pc.pcl{border-left:1px solid rgba(0,229,255,.14);border-right:1px solid rgba(0,229,255,.14);background:rgba(0,229,255,.03);}
.badge{display:inline-block;padding:5px 10px;border-radius:4px;font-size:11px;font-weight:700;letter-spacing:.2px;border:1px solid transparent;white-space:nowrap;line-height:1.1;transition:transform .12s;}
.badge:hover{transform:scale(1.07);}
.b1{background:rgba(0,200,83,.11);color:#00c853;border-color:rgba(0,200,83,.28);}
.b1x{background:rgba(0,200,83,.07);color:#69f0ae;border-color:rgba(0,200,83,.18);}
.bx2{background:rgba(255,61,90,.08);color:#ff8a80;border-color:rgba(255,61,90,.2);}
.bkg{background:rgba(0,229,255,.09);color:#00e5ff;border-color:rgba(0,229,255,.28);}
.bu{background:rgba(199,125,255,.1);color:#c77dff;border-color:rgba(199,125,255,.25);}
.ba{background:rgba(255,145,0,.08);color:#ffab40;border-color:rgba(255,145,0,.2);}
.bdash{background:rgba(255,255,255,.04);color:var(--muted);border-color:var(--border);letter-spacing:1px;}
td.pcl .badge{font-size:12px;padding:6px 11px;}

/* ─── SECTION ─── */
.sec{max-width:1300px;margin:0 auto;padding:0 24px;}
.sec-gap{margin-top:40px;}
.sec-title{font-family:'Bebas Neue',cursive;font-size:22px;letter-spacing:3px;color:#fff;margin-bottom:14px;}
.sec-title span{color:var(--accent);}

/* ─── CONSENSUS ─── */
.cg{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:8px;}
.cc{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:14px 16px;transition:border-color .2s,transform .2s;}
.cc:hover{border-color:rgba(0,229,255,.3);transform:translateY(-2px);}
.cc-m{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;margin-bottom:4px;}
.cc-p{font-size:16px;font-weight:700;color:#fff;margin-bottom:7px;}
.cc-bg{height:4px;background:var(--border);border-radius:3px;overflow:hidden;}
.cc-bar{height:100%;border-radius:3px;transition:width 1.3s cubic-bezier(.4,0,.2,1);}
.cc-n{font-size:10px;color:var(--muted);margin-top:4px;}

/* ─── AI CARDS ─── */
.ag{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:8px;}
.ac{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:15px 12px;text-align:center;transition:border-color .2s,transform .2s;}
.ac:hover{border-color:rgba(0,229,255,.35);transform:translateY(-3px);}
.ac.act{border-color:var(--accent);background:rgba(0,229,255,.05);}
.ac svg{width:32px;height:32px;margin:0 auto 8px;display:block;}
.ac-name{font-weight:700;font-size:13px;margin-bottom:2px;}
.ac-desc{font-size:10px;color:var(--muted);}

/* ─── STATIC PAGES (About, Privacy, Contact) ─── */
.static-page{max-width:760px;margin:0 auto;padding:40px 24px 60px;}
.static-page h2{font-family:'Bebas Neue',cursive;font-size:28px;letter-spacing:3px;color:#fff;margin-bottom:6px;}
.static-page h2 span{color:var(--accent);}
.static-page .sp-sub{font-size:12px;color:var(--muted);margin-bottom:32px;padding-bottom:16px;border-bottom:1px solid var(--border);}
.static-page h3{font-size:14px;font-weight:700;color:var(--accent);margin:24px 0 8px;text-transform:uppercase;letter-spacing:.5px;}
.static-page p{font-size:13px;color:var(--muted);line-height:1.75;margin-bottom:12px;}
.static-page a{color:var(--accent);text-decoration:none;}
.static-page a:hover{text-decoration:underline;}
.contact-form{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:24px;}
.form-row{margin-bottom:16px;}
.form-row label{display:block;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;}
.form-row input,.form-row textarea{width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:10px 14px;font-size:13px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;transition:border-color .15s;}
.form-row input:focus,.form-row textarea:focus{border-color:var(--accent);}
.form-row textarea{min-height:110px;resize:vertical;}
.form-btn{background:var(--accent);color:#000;font-size:13px;font-weight:700;padding:10px 28px;border:none;border-radius:6px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:opacity .15s;}
.form-btn:hover{opacity:.85;}

/* ─── ADUNIT ─── */
.ad-unit{width:100%;min-height:90px;background:rgba(255,255,255,.02);border:1px dashed rgba(255,255,255,.06);border-radius:6px;overflow:hidden;margin:20px 0;}

/* ─── DISCLAIMER ─── */
.dis{background:rgba(255,61,90,.04);border:1px solid rgba(255,61,90,.16);border-radius:8px;padding:12px 18px;font-size:11px;color:#ef9a9a;line-height:1.6;display:flex;gap:10px;align-items:flex-start;margin-top:40px;}
.dis strong{color:var(--accent2);}

/* ─── FOOTER ─── */
footer{border-top:1px solid var(--border);margin-top:36px;padding:20px 24px;display:flex;flex-direction:column;align-items:center;gap:6px;text-align:center;}
.flogo{font-family:'Bebas Neue',cursive;font-size:17px;letter-spacing:3px;color:var(--accent);}
.flogo span{color:var(--accent2);}
.flinks{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;}
.flinks a{font-size:11px;color:var(--muted);text-decoration:none;transition:color .15s;}
.flinks a:hover{color:var(--accent);}
.fsmall{font-size:10px;color:#2e3455;margin-top:2px;}

/* ─── MOBILE CARD VIEW ─── */
.match-card{display:none;background:var(--card);border:1px solid var(--border);border-radius:10px;margin:8px 16px;overflow:hidden;}
.match-card-header{padding:12px 14px 8px;border-bottom:1px solid var(--border);}
.match-card-teams{font-size:14px;font-weight:700;color:#fff;display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.match-card-teams .vs{color:var(--muted);font-weight:400;font-size:11px;}
.match-card-meta{font-size:10px;color:var(--muted);margin-top:4px;}
.match-card-preds{display:grid;grid-template-columns:1fr 1fr;gap:0;}
.match-card-pred{display:flex;align-items:center;justify-content:space-between;padding:7px 14px;border-bottom:1px solid rgba(30,35,64,.5);}
.match-card-pred:nth-child(odd){border-right:1px solid rgba(30,35,64,.5);}
.match-card-pred:nth-last-child(-n+2){border-bottom:none;}
.match-card-ai{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;}

/* ─── MOBILE ─── */
.sb-toggle{display:none;position:fixed;bottom:20px;right:16px;z-index:400;width:44px;height:44px;border-radius:50%;background:var(--accent);border:none;color:#000;font-size:18px;cursor:pointer;align-items:center;justify-content:center;box-shadow:0 4px 18px rgba(0,229,255,.35);}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.content>*{animation:fadeUp .4s ease both;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
@media(max-width:768px){
  :root{--sidebar-w:0px;}
  .sidebar{transform:translateX(-220px);}
  .sidebar.open{transform:translateX(0);width:220px;}
  .main{margin-left:0;}
  .sb-toggle{display:flex;}
  .topnav{padding:0 12px;}
  .topnav-breadcrumb{display:none;}
  .week-chip{font-size:10px;padding:4px 8px;}
  .title-bar,.legend-bar{padding-left:12px;padding-right:12px;}
  .legend-bar{flex-wrap:wrap;gap:4px;}
  .sec{padding:0 12px;}
  .static-page{padding:24px 16px 40px;}
  .table-wrap{display:none;}
  .match-card{display:block;}
  a.match-card{display:block;}
  .ag{grid-template-columns:repeat(3,1fr);}
  .cg{grid-template-columns:1fr;}
}


/* ─── SEO LANDING PAGE ADDITIONS ─── */
.seo-hero{max-width:1180px;margin:0 auto;padding:44px 24px 26px;position:relative;overflow:hidden;}
.seo-hero::before{content:'';position:absolute;right:24px;top:20px;width:260px;height:260px;background:radial-gradient(circle,rgba(0,229,255,.13),transparent 62%);pointer-events:none;}
.seo-kicker{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:10px;}
.seo-hero h1{font-family:'DM Sans',sans-serif;font-size:clamp(28px,4.8vw,56px);line-height:1.02;letter-spacing:-1.6px;color:#fff;max-width:880px;margin-bottom:14px;}
.seo-hero h1 span{color:var(--accent);}
.seo-lead{font-size:16px;line-height:1.75;color:#aab2d5;max-width:780px;margin-bottom:22px;}
.seo-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:18px;}
.seo-btn{display:inline-flex;align-items:center;gap:8px;text-decoration:none;border-radius:8px;padding:12px 18px;font-size:13px;font-weight:800;letter-spacing:.2px;transition:transform .15s,border-color .15s,background .15s;}
.seo-btn.primary{background:var(--accent);color:#001015;}
.seo-btn.secondary{border:1px solid var(--border);color:var(--text);background:rgba(255,255,255,.03);}
.seo-btn:hover{transform:translateY(-2px);}
.seo-grid{max-width:1180px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1.15fr .85fr;gap:18px;}
.seo-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:22px;box-shadow:0 8px 30px rgba(0,0,0,.18);}
.seo-card h2{font-size:20px;color:#fff;margin-bottom:12px;letter-spacing:-.3px;}
.seo-card h3{font-size:15px;color:var(--accent);margin:18px 0 8px;text-transform:uppercase;letter-spacing:.5px;}
